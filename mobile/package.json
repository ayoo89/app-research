  "private": true,
  "main": "index.js",
  "engines": {
    "node": ">=18.0.0 <23.0.0"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "build:all": "eas build --platform all",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "node --max-old-space-size=8192 node_modules/jest/bin/jest.js --forceExit",
    "test:watch": "node --max-old-space-size=8192 node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --max-old-space-size=8192 node_modules/jest/bin/jest.js --coverage --forceExit"
  },
