    "@react-navigation/native-stack": "^6.9.0",
    "axios": "^1.6.0",
    "expo": "~51.0.0",
    "expo-camera": "~15.0.0",
    "expo-constants": "~16.0.0",
    "expo-dev-client": "~4.0.0",
    "expo-document-picker": "~12.0.2",
    "expo-file-system": "~17.0.0",
