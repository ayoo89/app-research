# ── Instructions ──────────────────────────────────────────────────────────────
# 1. Copy this file to:  mobile/android/local.properties
# 2. Fill in the values below
# 3. local.properties is in .gitignore — never commit it
# ──────────────────────────────────────────────────────────────────────────────

# Android SDK path — Android Studio sets this automatically.
# If missing, set it manually:
# Windows:
#   sdk.dir=C\:\\Users\\YourName\\AppData\\Local\\Android\\Sdk
# Mac/Linux:
#   sdk.dir=/Users/YourName/Library/Android/sdk

# Node.js path — required when building from Android Studio (it doesn't
# inherit your system PATH). Find your Node path:
#   Windows: open CMD and run:  where node
#   Mac/Linux: open Terminal:   which node
#
# Windows example (escape backslashes with \\):
#   nodejs.dir=C\:\\Program Files\\nodejs
#
# Mac example:
#   nodejs.dir=/usr/local/bin
#
# If you installed Node via nvm on Windows:
#   nodejs.dir=C\:\\Users\\YourName\\AppData\\Roaming\\nvm\\v22.0.0
